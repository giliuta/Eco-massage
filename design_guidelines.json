  "universal_guidelines": [
    "Do NOT use 'Inter' for headings. Use Montserrat.",
    "Do NOT use gradients for dark backgrounds; use solid dark colors with subtle noise or glowing accents.",
    "Use 'framer-motion' for all entrance animations.",
    "Ensure 4.5:1 contrast ratio for text.",
    "Mobile images must be max-h-[80vh].",
    "All interactive elements must have 'data-testid'.",
    "Use 'lucide-react' for icons."
  ],
  "instructions_to_main_agent": "1. Install 'lucide-react', 'framer-motion', 'react-icons' if not present. 2. Create the folder structure for components if missing. 3. Implement the Layout first, then Hero, then other sections. 4. Use the provided image URLs. 5. Ensure the OPEN/CLOSED badge logic uses the correct timezone (Europe/Nicosia). 6. Use Shadcn components for complex interactions (Accordion, Dialog, Carousel) but style them to match the dark theme.",
  "tech_stack": {
    "framework": "React",
    "styling": "Tailwind CSS",
    "components": "Shadcn/UI",
    "icons": "Lucide React",
    "animation": "Framer Motion",
    "state_management": "React Context (for Language)"
  }
