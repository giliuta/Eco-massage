{
  "identity": {
    "persona": "E1",
    "tone": "High-Tech Luxury, Scientific Wellness, Futuristic, Premium",
    "theme_strategy": "Dark Mode Dominant with Electric Blue/Cyan Accents"
  },
  "typography": {
    "headings": {
      "font_family": "Montserrat",
      "weight": "900",
      "style": "uppercase",
      "letter_spacing": "tracking-widest (0.2em)",
      "usage": "Hero titles, Section headers"
    },
    "body": {
      "font_family": "Inter, DM Sans",
      "weight": "400/500",
      "usage": "Paragraphs, descriptions, lists"
    },
    "accents": {
      "font_family": "Montserrat",
      "weight": "700",
      "usage": "Buttons, Nav links, Badges"
    }
  },
  "colors": {
    "primary": "#0055FF",
    "secondary": "#00D4FF",
    "accent": "#D4A853",
    "background_dark": "#0A0E1A",
    "background_light": "#F5F7FA",
    "surface_dark": "#111625",
    "surface_glass": "rgba(255, 255, 255, 0.05)",
    "text_primary_dark": "#FFFFFF",
    "text_secondary_dark": "#A0AEC0",
    "text_primary_light": "#0A0E1A",
    "success": "#10B981",
    "error": "#EF4444"
  },
  "visual_enhancers": {
    "glassmorphism": {
      "classes": "backdrop-blur-xl bg-white/5 border border-white/10 shadow-xl",
      "usage": "Cards, Sticky Header, Floating Elements"
    },
    "glow_effects": {
      "blue_led": "shadow-[0_0_20px_rgba(0,85,255,0.5)]",
      "cyan_pulse": "shadow-[0_0_15px_rgba(0,212,255,0.4)]",
      "text_glow": "drop-shadow-[0_0_8px_rgba(0,212,255,0.5)]"
    },
    "gradients": {
      "hero_overlay": "bg-gradient-to-b from-transparent via-background_dark/50 to-background_dark",
      "tech_accent": "bg-gradient-to-r from-primary to-secondary"
    },
    "borders": {
      "style": "1px solid rgba(255,255,255,0.1)",
      "radius": "rounded-2xl"
    }
  },
  "layout_strategy": {
    "grid_system": "Bento Grid (Mode A for Marketing, Mode B for Features)",
    "spacing": "Generous (p-8 to p-32)",
    "container": "max-w-7xl mx-auto px-4 sm:px-6 lg:px-8",
    "mobile_first": "Stack vertically on mobile, grid on lg screens",
    "z_index": {
      "sticky_nav": "z-50",
      "modal": "z-50",
      "floating_cta": "z-40",
      "content": "z-10",
      "background": "z-0"
    }
  },
  "components": {
    "header": {
      "type": "Sticky Glassmorphism",
      "features": ["Language Switcher (RU/EN/EL)", "Logo", "Nav Links", "Book Now CTA"],
      "path": "/app/frontend/src/components/layout/Header.js"
    },
    "hero": {
      "type": "Full Screen Immersive",
      "features": ["Video/Image Background", "Animated Text", "OPEN/CLOSED Badge", "Primary CTA"],
      "path": "/app/frontend/src/components/sections/Hero.js"
    },
    "badges": {
      "open_closed": {
        "logic": "Real-time Europe/Nicosia timezone check",
        "style": "Pill shape, pulsing dot (Green=Open, Red=Closed)",
        "path": "/app/frontend/src/components/ui/StatusBadge.js"
      }
    },
    "cards": {
      "service_card": "Glassmorphism, hover lift, glow border on hover",
      "pricing_card": "Premium border, list of features, Gold CTA",
      "testimonial_card": "Video thumbnail or quote with avatar"
    },
    "forms": {
      "lead_form": "Shadcn Form, Zod Validation, Floating Labels, Gold Submit Button",
      "path": "/app/frontend/src/components/sections/ContactForm.js"
    },
    "whatsapp_button": {
      "style": "Floating bottom-right, Green brand color, Pulse effect",
      "path": "/app/frontend/src/components/ui/WhatsAppButton.js"
    }
  },
  "motion": {
    "library": "framer-motion",
    "types": {
      "fade_up": {
        "initial": { "opacity": 0, "y": 20 },
        "whileInView": { "opacity": 1, "y": 0 },
        "viewport": { "once": true }
      },
      "stagger_children": {
        "container": { "transition": { "staggerChildren": 0.1 } }
      },
      "hover_scale": {
        "whileHover": { "scale": 1.02 }
      }
    }
  },
